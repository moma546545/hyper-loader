{
  "manifest_version": 3,
  "name": "VidDownloader Integration",
  "version": "1.1.0",
  "description": "Send links directly to VidDownloader desktop app.",
  "permissions": [
    "contextMenus",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "*://127.0.0.1/*",
    "*://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "128": "icon.ico"
  }
}
